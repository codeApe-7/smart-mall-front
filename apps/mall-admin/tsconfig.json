{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../../packages/shared/src/*"],
      "@mall-admin/*": ["src/*"]
    }
  },
  "include": [
    "src/main.ts",
    "src/App.vue",
    "src/env.d.ts",
    "src/router/**/*.ts",
    "src/layouts/AdminLayout.vue",
    "src/views/auth/**/*.vue",
    "src/views/dashboard/**/*.vue",
    "src/views/product/**/*.vue",
    "src/views/order/**/*.vue",
    "src/views/user/**/*.vue",
    "src/views/notice/**/*.vue",
    "src/views/ai/**/*.vue",
    "src/views/authority/**/*.vue",
    "src/components/**/*.vue",
    "src/stores/**/*.ts",
    "src/api/**/*.ts",
    "../../packages/shared/src/**/*.ts"
  ]
}
