{
  "name": "smart-mall-front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:user": "vite --config apps/mall-user/vite.config.ts",
    "dev:admin": "vite --config apps/mall-admin/vite.config.ts",
    "build:user": "vite build --config apps/mall-user/vite.config.ts",
    "build:admin": "vite build --config apps/mall-admin/vite.config.ts",
    "build": "npm run build:user && npm run build:admin",
    "typecheck:user": "vue-tsc --project apps/mall-user/tsconfig.json --noEmit",
    "typecheck:admin": "vue-tsc --project apps/mall-admin/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:user && npm run typecheck:admin"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.8.4",
    "echarts": "^5.6.0",
    "element-plus": "^2.11.5",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.86.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vue-tsc": "^2.2.8"
  }
}
